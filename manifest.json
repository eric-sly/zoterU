{
	"manifest_version": 2,
	"name": "sly's zotero",
	"version": "1.2.4",
	"description": "Parse Zotero PDFs with MinerU, attach Markdown folders, and expose the workflow over local MCP.",
	"homepage_url": "https://example.com/codex-md-attach-bridge",
	"author": "Codex",
	"icons": {
		"48": "icon.svg",
		"96": "icon.svg"
	},
	"applications": {
		"zotero": {
			"id": "codex-md-attach-bridge@example.com",
			"update_url": "https://example.com/codex-md-attach-bridge/update.json",
			"strict_min_version": "9.0",
			"strict_max_version": "9.*"
		}
	}
}
