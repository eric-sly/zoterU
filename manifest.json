{
	"manifest_version": 2,
	"name": "Zotero MinerU",
	"version": "1.4.0",
	"description": "Parse Zotero PDFs with MinerU, attach Markdown folders, and expose the workflow over local MCP.",
	"homepage_url": "https://github.com/eric-sly/zotero-mineru",
	"author": "eric-sly",
	"icons": {
		"48": "icon.svg",
		"96": "icon.svg"
	},
	"applications": {
		"zotero": {
			"id": "zotero-mineru@github.io",
			"update_url": "https://github.com/eric-sly/zotero-mineru/releases/latest/download/update.json",
			"strict_min_version": "9.0",
			"strict_max_version": "9.*"
		}
	}
}
